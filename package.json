{
  "name": "romantic-oracle-raven",
  "version": "1.0.0",
  "description": "致力于用技术打低恋爱所需要的成本",
  "main": "index.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "NODE_ENV=development node server/server.js",
    "prod": "NODE_ENV=production node server/server.js",
    "test": "jest --testPathPattern=server/",
    "test:web": "cd client/web && npm run test",
    "test:mobile": "cd client/mobile && npm run test",
    "test:security": "node test-security.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:force": "npm audit fix --force",
    "security-check": "npm audit && node test-security.js",
    "generate-secret": "node -e \"console.log('JWT_ACCESS_SECRET=' + require('crypto').randomBytes(32).toString('base64'))\"",
    "lint:security": "echo '安全代码检查...' && node -e \"console.log('✓ JWT工具: ' + (require('fs').existsSync('server/utils/jwtUtils.js') ? '存在' : '缺失'))\" && node -e \"console.log('✓ 密码工具: ' + (require('fs').existsSync('server/utils/passwordUtils.js') ? '存在' : '缺失'))\" && node -e \"console.log('✓ 速率限制: ' + (require('fs').existsSync('server/middleware/rateLimit.js') ? '存在' : '缺失'))\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "abort-controller": "^3.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^4.13.0",
    "mongoose": "^6.12.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "onnxruntime-node": "^1.24.2",
    "openai": "^6.16.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "jest-mongoose-mock": "^1.2.0",
    "supertest": "^6.3.3"
  }
}
