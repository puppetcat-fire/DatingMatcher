# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/datingmatcher

# Authentication
JWT_SECRET=your_jwt_secret_key_change_this

# DeepSeek / OpenAI / Qwen API Configuration

# 1. Alibaba Cloud (Qwen) - For Embeddings
# Base URL (e.g., https://dashscope.aliyuncs.com/compatible-mode/v1)
ALI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# API Key
ALI_API_KEY=your_ali_api_key_here
# Embedding Model Name (e.g., text-embedding-v1)
ALI_EMBEDDING_MODEL=text-embedding-v1

# 2. DeepSeek - For Chat & Scenarios
# Base URL (e.g., https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com
# API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Chat Model Name (e.g., deepseek-chat)
DEEPSEEK_CHAT_MODEL=deepseek-chat
